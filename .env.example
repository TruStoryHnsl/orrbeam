# Orrbeam environment variable overrides
#
# Copy this file to .env and adjust as needed. Values here supplement
# ~/.config/orrbeam/config.yaml — environment variables take precedence
# where the application explicitly reads them.

# Logging level for the Rust backend (tracing EnvFilter syntax).
# Default: orrbeam=info
# Examples: orrbeam=debug | orrbeam_net=trace,orrbeam_core=debug | info
RUST_LOG=orrbeam=info

# Override the control-plane bind address (default: 0.0.0.0).
# Useful for restricting to a specific interface during development.
# ORRBEAM_API_BIND=127.0.0.1

# Override the control-plane port (default: 47782).
# ORRBEAM_API_PORT=47782

# Override the orrtellite (Headscale) URL — also settable in config.yaml.
# ORRBEAM_ORRTELLITE_URL=https://hs.example.com

# Override the orrtellite API key — prefer config.yaml or a secrets manager.
# ORRBEAM_ORRTELLITE_API_KEY=

# Override the Sunshine binary path (auto-detected if not set).
# ORRBEAM_SUNSHINE_PATH=/usr/bin/sunshine

# Override the Moonlight binary path (auto-detected if not set).
# ORRBEAM_MOONLIGHT_PATH=/usr/bin/moonlight-qt
